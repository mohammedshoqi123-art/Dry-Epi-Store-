# ============================================================
# EPI Supervisor Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control!
# ============================================================

# ─── Supabase ────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Project ref for CLI operations (from the URL above)
SUPABASE_PROJECT_REF=your-project-ref

# ─── Gemini AI (Optional) ───────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Sentry Monitoring (Optional) ────────────────────────────
# Get from: https://sentry.io → Create Project → Flutter
SENTRY_DSN=

# ─── App Configuration ────────────────────────────────────────
APP_ENV=production
APP_NAME=EPI Supervisor
APP_NAME_AR=منصة مشرف EPI

# ─── Admin User ─────────────────────────────────────────────
# The admin user should already exist in Supabase Auth
# If not, use the create-admin Edge Function to create it
ADMIN_EMAIL=admin@example.com
ADMIN_FULL_NAME=مدير النظام

# ─── CORS (Edge Functions) ────────────────────────────────────
# ⚠️ REQUIRED for Web — Edge Functions will BLOCK browser requests without this!
# Add ALL domains that access Edge Functions:
# - Admin web panel URL
# - Flutter web URL (if deploying Flutter web)
# - Local development URLs
#
# Set this in: Supabase Dashboard → Edge Functions → Secrets
# Example:
#   ALLOWED_ORIGINS=https://admin.yourdomain.com,https://app.yourdomain.com,http://localhost:5173
ALLOWED_ORIGINS=https://mohammedshoqi123-art.github.io,http://localhost:5173

# ─── Encryption ───────────────────────────────────────────────
# Used for local Hive storage encryption
# ⚠️ MUST be at least 32 characters — NEVER use the default in production!
# Generate a random key: openssl rand -base64 32
ENCRYPTION_KEY=

# ─── Build ────────────────────────────────────────────────────
FLUTTER_BUILD_MODE=release
