# ============================================================
# EPI Supervisor Platform — .gitignore
# ============================================================

# ─── Flutter / Dart ────────────────────────────────────────
.dart_tool/
.packages
build/
.pub-cache/
.pub/
.flutter-plugins
.flutter-plugins-dependencies
*.iml
.idea/
.vscode/
*.swp
*.swo

# ─── Generated Files ───────────────────────────────────────
*.g.dart
*.freezed.dart
*.mocks.dart

# ─── Android ───────────────────────────────────────────────
**/android/.gradle/
**/android/captures/
**/android/local.properties
**/android/key.properties
*.jks
*.keystore

# ─── iOS ───────────────────────────────────────────────────
**/ios/**/*.symlink
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*

# ─── Web ───────────────────────────────────────────────────
**/web/favicon.png
**/web/icons/

# ─── Environment & Secrets ─────────────────────────────────
.env
.env.local
.env.production
*.pem
*.key

# ─── Supabase ──────────────────────────────────────────────
supabase/.branches/
supabase/.temp/

# ─── OS Files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Logs ──────────────────────────────────────────────────
*.log
logs/

# ─── Coverage ──────────────────────────────────────────────
coverage/

# Local properties
**/android/local.properties

# ─── Android Local Config ───────────────────────────────────
**/android/local.properties
**/android/app/google-services.json
